{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "西方戰術 SRPG",
  "version": "0.1.0",
  "identifier": "com.web-srpg.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "西方戰術 SRPG",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "西方奇幻戰術 SRPG",
    "longDescription": "個人開發的瀏覽器戰術角色扮演遊戲，靈感取自《天使帝國》、《火焰之紋章》、《三國志》系列。",
    "icon": []
  }
}
